# Rwanda RPPA OCDS API
UMUCYO_API_BASE=https://umucyo.gov.rw

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=your_meta_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
ADMIN_WHATSAPP_NUMBER=250700000000

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
FLASK_SECRET_KEY=change_this_to_a_random_secret
DATABASE_PATH=./backend/tenderalert.db

# Admin Dashboard
ADMIN_PASSWORD=change_this_to_a_strong_password
JWT_SECRET=change_this_to_a_random_32_char_string
CORS_ORIGINS=http://localhost:3000
